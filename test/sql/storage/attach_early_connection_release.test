# name: test/sql/storage/attach_early_connection_release.test
# description: Covers parallel scan correctness for releasing connection with best effort.
# group: [storage]

require postgres_scanner

require-env POSTGRES_TEST_DATABASE_AVAILABLE

statement ok
PRAGMA enable_verification

statement ok
ATTACH 'dbname=postgresscanner' AS s (TYPE POSTGRES);

statement ok
USE s

# create tables with enough data to exercise parallel scans
statement ok
CREATE OR REPLACE TABLE early_release_t1(i INTEGER, j INTEGER);

statement ok
INSERT INTO early_release_t1 SELECT i, i % 100 FROM generate_series(0, 99999) t(i)

statement ok
CREATE OR REPLACE TABLE early_release_t2(j INTEGER, k TEXT);

statement ok
INSERT INTO early_release_t2 SELECT i, 'val_' || i::TEXT FROM generate_series(0, 99) t(i)

# set a very tight connection limit and small pages per task to force many parallel scan tasks
# with early connection release, pool connections from the first table's scan are returned
# before the second table's scan begins, allowing it to also use pool connections
statement ok
SET pg_connection_limit=2

statement ok
SET pg_pages_per_task=1

# query that scans two postgres tables then does DuckDB-side join/group by/order by
# t1 SUM(i) grouped by j: for j=99, sum = 99+199+...+99999 = 50049000
query II
SELECT t2.k, SUM(t1.i)
FROM early_release_t1 t1
JOIN early_release_t2 t2 ON t1.j = t2.j
GROUP BY t2.k
ORDER BY SUM(t1.i) DESC
LIMIT 5
----
val_99	50049000
val_98	50048000
val_97	50047000
val_96	50046000
val_95	50045000

# verify a second query also works - confirms pool connections were properly returned
query I
SELECT SUM(t1.i)
FROM early_release_t1 t1
JOIN early_release_t2 t2 ON t1.j = t2.j
WHERE t2.j < 10
----
499545000

# clean up
statement ok
DROP TABLE IF EXISTS early_release_t1

statement ok
DROP TABLE IF EXISTS early_release_t2
