# name: test/sql/storage/attach_types_json.test
# description: Test inserting/querying json/jsonb
# group: [storage]

require postgres_scanner

require-env POSTGRES_TEST_DATABASE_AVAILABLE

statement ok
ATTACH 'dbname=postgresscanner' AS s (TYPE POSTGRES)

statement ok
USE s;

foreach plain FALSE TRUE

statement ok
SET pg_use_text_protocol = {plain}

query I
SELECT * FROM pg_json
----
{"a": 42, "b": "string"}

statement ok
DELETE FROM pg_json

statement ok
INSERT INTO pg_json VALUES ('{"a": 42, "b": "string"}')

query I
SELECT * FROM pg_json
----
{"a": 42, "b": "string"}

endloop

statement ok
RESET pg_use_text_protocol 
